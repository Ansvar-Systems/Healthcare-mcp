{
  "name": "@ansvar/healthcare-mcp",
  "version": "0.1.0",
  "mcpName": "eu.ansvar/healthcare-intelligence",
  "description": "Healthcare domain-intelligence MCP for architecture-aware threat modeling across EU and US",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "healthcare-mcp": "./dist/src/index.js"
  },
  "files": [
    "dist/",
    "data/healthcare.db",
    "data/seed/",
    "README.md",
    "CHANGELOG.md",
    "server.json",
    "sources.yml"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/src/index.js dist/src/http-server.js",
    "build:db": "node --no-warnings --import tsx scripts/build-db.ts",
    "drift:hashes": "node --no-warnings --import tsx scripts/generate-drift-hashes.ts",
    "drift:verify": "node --no-warnings --import tsx scripts/verify-drift-hashes.ts",
    "check:source-updates": "node --no-warnings --import tsx scripts/check-source-updates.ts",
    "verify:release": "node --no-warnings --import tsx scripts/verify-release-integrity.ts",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx --watch src/http-server.ts",
    "start:http": "node dist/src/http-server.js",
    "test": "npm run build:db && vitest run",
    "test:benchmark": "npm run build:db && vitest run tests/benchmark-grade.test.ts",
    "test:coverage": "npm run build:db && node --no-warnings --import tsx scripts/check-tool-coverage.ts",
    "test:live": "LIVE_UPSTREAM_TESTS=1 vitest run tests/live-authoritative-regression.test.ts",
    "test:live:strict": "LIVE_UPSTREAM_TESTS=1 LIVE_STRICT=1 vitest run tests/live-authoritative-regression.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:ci": "npm run build && npm test && npm run test:coverage && npm run drift:verify",
    "verify:db": "test -f data/healthcare.db && echo '✅ Database exists' || (echo '❌ Database missing' && exit 1)",
    "prepublishOnly": "npm run test:ci && npm run verify:db"
  },
  "keywords": [
    "mcp",
    "healthcare",
    "threat-modeling",
    "hipaa",
    "gdpr",
    "nis2",
    "fhir",
    "medical-devices"
  ],
  "author": "Ansvar Systems",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ansvar-Systems/Healthcare-mcp.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0"
  },
  "devDependencies": {
    "@types/node": "22.13.1",
    "@vercel/node": "5.6.3",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "4.0.18"
  },
  "overrides": {
    "ajv": "8.18.0",
    "path-to-regexp": "8.0.0",
    "undici": "7.0.0"
  }
}
